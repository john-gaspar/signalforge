{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "summary_v1",
  "type": "object",
  "required": ["issue", "cluster_count", "evidence"],
  "properties": {
    "issue": { "type": "string" },
    "cluster_count": { "type": "integer", "minimum": 0 },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["cluster_id", "members"],
        "properties": {
          "cluster_id": { "type": "string", "minLength": 1 },
          "members": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
